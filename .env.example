# Copy this file to .env and fill in your values
# On Netlify: add these in Site Settings > Environment Variables

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API Keys
VITE_GOOGLE_MAPS_API_KEY=your-primary-maps-key
VITE_GOOGLE_MAPS_JAVASCRIPT_API_KEY=your-javascript-api-key
VITE_GOOGLE_PLACES_API_KEY=your-places-api-key
VITE_GOOGLE_GEOCODING_API_KEY=your-geocoding-api-key
VITE_GOOGLE_GEOLOCATION_API_KEY=your-geolocation-api-key
VITE_GOOGLE_DISTANCE_MATRIX_API_KEY=your-distance-matrix-api-key
VITE_GOOGLE_DIRECTIONS_API_KEY=your-directions-api-key
VITE_GOOGLE_ROADS_API_KEY=your-roads-api-key

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_VAPID_KEY=your-vapid-key
